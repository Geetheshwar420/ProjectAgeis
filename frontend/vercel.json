{
  "version": 2,
  "config": {
    "distDir": "dist"
  },
  "routes": [
    {
      "src": "/manifest.webmanifest",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "/registerSW.js",
      "dest": "/registerSW.js"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://projectageis.onrender.com"
  }
}
